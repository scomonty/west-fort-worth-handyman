---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
const phone = "(682) 703-0033";
---

<BaseLayout
  title="Drywall Repair Fort Worth TX | West Fort Worth Handyman"
  description="Professional drywall repair in Fort Worth. Hole repair, patching, texture matching, and wall damage repair. Call today for a free estimate."
>
  <Navbar />
  <!-- HERO -->
  <section class="pt-40 pb-24 bg-brand-offwhite text-center">
    <div class="max-w-3xl mx-auto px-6">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">
        Professional Drywall Repair in Fort Worth
      </h1>

      <p class="text-lg text-brand-gray mb-8">
        Holes, cracks, dents, and wall damage repaired quickly and
        professionally. Seamless patching and texture matching.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`tel:${phone}`}
          data-astro-reload
          class="bg-brand-red text-white px-8 py-4 rounded-lg font-semibold"
        >
          Call Now — Free Estimate
        </a>

        <a
          href="/contact"
          class="border border-brand-navy px-8 py-4 rounded-lg"
        >
          Request Estimate
        </a>
      </div>

      <p class="mt-4 text-sm text-brand-gray">
        Serving West Fort Worth, Benbrook, White Settlement, Aledo & nearby
        areas
      </p>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-brand-navy text-center mb-10">
        Drywall Repair Services
      </h2>

      <div class="grid md:grid-cols-2 gap-6 text-brand-gray">
        <p>• Hole repair (small & large)</p>
        <p>• Wall crack repair</p>
        <p>• Water damage repair</p>
        <p>• Texture matching</p>
        <p>• Nail pops & dents</p>
        <p>• Ceiling drywall repair</p>
        <p>• Sheetrock patching</p>
        <p>• Seam repair</p>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE -->
  <section class="py-20 bg-brand-offwhite">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">
        Why Choose West Fort Worth Handyman
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <h3 class="font-semibold">Seamless Repairs</h3>
          <p class="text-brand-gray">
            Clean patches and texture blending that match your existing walls.
          </p>
        </div>

        <div>
          <h3 class="font-semibold">Affordable Pricing</h3>
          <p class="text-brand-gray">Transparent pricing and free estimates.</p>
        </div>

        <div>
          <h3 class="font-semibold">Local Fort Worth Service</h3>
          <p class="text-brand-gray">
            Reliable service from a trusted local handyman.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold text-brand-navy mb-10">
        Our Repair Process
      </h2>

      <div class="grid md:grid-cols-3 gap-8 text-brand-gray">
        <div>
          <h3 class="font-semibold mb-2">1. Inspect Damage</h3>
          <p>We assess the damage and recommend the best repair.</p>
        </div>

        <div>
          <h3 class="font-semibold mb-2">2. Patch & Repair</h3>
          <p>Professional patching and finishing.</p>
        </div>

        <div>
          <h3 class="font-semibold mb-2">3. Texture Match</h3>
          <p>Blended finish for a seamless look.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="py-24 bg-brand-navy text-white text-center">
    <h2 class="text-3xl font-bold mb-4">Need Drywall Repaired?</h2>

    <p class="mb-8">Call today or request a free estimate.</p>

    <a
      href={`tel:${phone}`}
      data-astro-reload
      class="bg-brand-red px-8 py-4 rounded-lg font-semibold"
    >
      Call Now
    </a>
  </section>
</BaseLayout>

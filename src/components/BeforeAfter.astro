---
const {
  id,
  title,
  city,
  state,
  before,
  after,
  description,
  scope,
  services = [],
  highlights = [],
} = Astro.props;
---

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "@id": `${Astro.url.href}#${title.replace(/\s+/g, "-")}`,

    name: title,
    description: description,

    creator: {
      "@id": "https://westfortworthhandyman.com/#business",
    },

    image: [before, after],
  })}
/>

<div class="bg-white rounded-xl shadow p-6">
  <!-- Title + Scope -->
  <div class="flex items-start justify-between mb-2">
    <h3 class="text-xl font-bold">{title}</h3>

    {
      scope && (
        <span class="text-xs bg-gray-100 px-3 py-1 rounded-full">{scope}</span>
      )
    }
  </div>

  <!-- Location -->
  {
    (city || state) && (
      <p class="text-sm text-gray-500 mb-4">
        {[city, state].filter(Boolean).join(", ")}
      </p>
    )
  }

  <!-- Images -->
  <div class="grid md:grid-cols-2 gap-4 mb-4">
    <div>
      <p class="text-sm font-semibold mb-2">Before</p>
      <img
        src={before}
        alt={`${title} before`}
        class="rounded-lg w-full h-64 object-cover cursor-pointer hover:opacity-90"
        onclick={`openImageModal('${id}', '${before}')`}
      />
    </div>

    <div>
      <p class="text-sm font-semibold mb-2">After</p>
      <img
        src={after}
        alt={`${title} after`}
        class="rounded-lg w-full h-64 object-cover cursor-pointer hover:opacity-90"
        onclick={`openImageModal('${id}', '${after}')`}
      />
    </div>
  </div>

  <!-- Description -->
  {description && <p class="text-brand-gray mb-4">{description}</p>}

  <!-- Highlights -->
  {
    highlights.length > 0 && (
      <ul class="text-sm text-gray-700 space-y-1 mb-4">
        {highlights.map((item) => (
          <li>✓ {item}</li>
        ))}
      </ul>
    )
  }

  <!-- Services Tags -->
  {
    services.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {services.map((service) => (
          <span class="text-xs bg-gray-100 px-3 py-1 rounded-full">
            {service}
          </span>
        ))}
      </div>
    )
  }

  <!-- MODAL -->
  <div
    id={`${id}-modal`}
    class="fixed inset-0 bg-black/80 flex items-center justify-center z-[9999] hidden"
    onclick={`closeImageModal('${id}')`}
  >
    <div class="relative max-w-4xl w-full p-4">
      <button
        class="absolute -top-10 right-0 text-white text-3xl"
        onclick={`closeImageModal('${id}')`}
      >
        ×
      </button>

      <img
        id={`${id}-modal-img`}
        class="w-full max-h-[80vh] object-contain rounded-lg"
      />
    </div>
  </div>
</div>

<script>
  window.openImageModal = (id, src) => {
    const modal = document.getElementById(`${id}-modal`);
    const img = document.getElementById(`${id}-modal-img`);

    if (!modal || !img) return;

    img.src = src;
    modal.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  };

  window.closeImageModal = (id) => {
    const modal = document.getElementById(`${id}-modal`);
    if (!modal) return;

    modal.classList.add("hidden");
    document.body.style.overflow = "auto";
  };

  // ESC key support
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      document.querySelectorAll("[id$='-modal']").forEach((m) => {
        m.classList.add("hidden");
      });
      document.body.style.overflow = "auto";
    }
  });
</script>

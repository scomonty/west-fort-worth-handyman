---
const {
  title,
  description,
  images = [],
  detailsUrl = null,
  detailsLabel = "Learn more about this service",
  highlights = [],
} = Astro.props;
---

<section class="py-8 border-gray-200 flex flex-col h-full">
  <h3 class="text-2xl font-bold text-brand-navy mb-4 text-center">
    {title}
  </h3>
  <div
    class={`grid gap-10 items-center ${images.length > 0 ? "md:grid-cols-2" : "grid-cols-1"}`}
  >
    <!-- TEXT -->
    <div>
      <p class="text-brand-gray mb-4">
        {description}
      </p>
    </div>

    <!-- IMAGE CAROUSEL -->
    {
      images.length > 0 && (
        <div class="relative">
          <img
            src={images[0]}
            data-images={JSON.stringify(images)}
            class="w-full h-80 object-cover rounded-xl"
            id={`${title}-img`}
          />

          {/* controls */}
          {images.length > 1 && (
            <>
              <button
                class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/80 px-3 py-1 rounded"
                onclick={`prevSlide("${title}")`}
              >
                ←
              </button>

              <button
                class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/80 px-3 py-1 rounded"
                onclick={`nextSlide("${title}")`}
              >
                →
              </button>
            </>
          )}
        </div>
      )
    }
  </div>
  <div class="flex flex-col h-full">
    {
      highlights && (
        <ul class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 text-sm text-brand-gray">
          {highlights.map((item) => (
            <li class="flex items-center gap-2">
              <span class="text-green-600 font-bold">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      )
    }

    {
      detailsUrl && (
        <a
          href={detailsUrl}
          class="inline-block text-brand-navy font-semibold underline hover:opacity-80 mt-auto pt-4 text-center"
        >
          {detailsLabel} →
        </a>
      )
    }
  </div>
</section>

<script>
  const carousels = {};

  window.nextSlide = (id) => {
    if (!carousels[id]) return;

    carousels[id].index =
      (carousels[id].index + 1) % carousels[id].images.length;

    document.getElementById(`${id}-img`).src =
      carousels[id].images[carousels[id].index];
  };

  window.prevSlide = (id) => {
    if (!carousels[id]) return;

    carousels[id].index =
      (carousels[id].index - 1 + carousels[id].images.length) %
      carousels[id].images.length;

    document.getElementById(`${id}-img`).src =
      carousels[id].images[carousels[id].index];
  };

  // initialize
  document.querySelectorAll("img[id$='-img']").forEach((img) => {
    const id = img.id.replace("-img", "");
    const images = JSON.parse(img.dataset.images || "[]");

    carousels[id] = { images, index: 0 };
  });
</script>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
---

<BaseLayout
  title="Flooring Installation in West Fort Worth | Laminate, Vinyl & Hardwood"
  description="Professional laminate, vinyl, and hardwood flooring installation in West Fort Worth. Reliable service, fair pricing, and quality workmanship."
>
  <Navbar />

  <section class="pt-40 pb-20 bg-brand-offwhite text-center">
    <div class="max-w-3xl mx-auto px-6">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">
        Affordable & Reliable Handyman in Fort Worth
      </h1>

      <p class="text-lg text-brand-gray mb-8">
        Fast home repairs, installations, and maintenance. Get a free estimate
        today.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:6827030033"
          data-astro-reload
          class="bg-brand-red text-white px-8 py-4 rounded-lg font-semibold"
        >
          Call Now
        </a>

        <a
          href="/contact"
          class="border border-brand-navy px-8 py-4 rounded-lg"
        >
          Request Estimate
        </a>
      </div>

      <p class="mt-4 text-sm text-brand-gray">
        Serving West Fort Worth, Benbrook, Aldeo, White Settlement & nearby
        areas
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold text-brand-navy mb-8">
        Why Choose West Fort Worth Handyman
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <h3 class="font-semibold">Affordable Pricing</h3>
          <p class="text-brand-gray">Transparent pricing with no surprises.</p>
        </div>

        <div>
          <h3 class="font-semibold">Reliable Service</h3>
          <p class="text-brand-gray">On time and professional workmanship.</p>
        </div>

        <div>
          <h3 class="font-semibold">Local Fort Worth Service</h3>
          <p class="text-brand-gray">Proudly serving your neighborhood.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-offwhite">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-brand-navy text-center mb-10">
        Handyman Services
      </h2>

      <div class="grid md:grid-cols-2 gap-6 text-brand-gray">
        <p>• Drywall repair</p>
        <p>• Door repair</p>
        <p>• Flooring installation</p>
        <p>• Light fixture installation</p>
        <p>• Ceiling fan installation</p>
        <p>• Faucet installation</p>
        <p>• Shelving & mounting</p>
        <p>• Home maintenance</p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-brand-navy text-white text-center">
    <h2 class="text-3xl font-bold mb-4">Ready to Fix Your Home Project?</h2>

    <p class="mb-8">Call today or request your free estimate.</p>

    <a
      href="tel:6827030033"
      data-astro-reload
      class="bg-brand-red px-8 py-4 rounded-lg font-semibold"
    >
      Call Now
    </a>
  </section>
</BaseLayout>

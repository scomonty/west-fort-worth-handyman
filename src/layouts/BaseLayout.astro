<!-- Google tag (gtag.js) -->
{isProd && GA_ID && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>

    <script define:vars={{ GA_ID, ADS_ID }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag = function(){dataLayer.push(arguments);}
      gtag('js', new Date());

      {/* GA4 */}
      gtag('config', GA_ID);

      {/* Google Ads */}
      gtag('config', ADS_ID);
    </script>

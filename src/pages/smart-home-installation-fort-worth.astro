---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";

const phone = "(682) 703-0033";
---

<BaseLayout
  title="Smart Home Installation Fort Worth TX | West Fort Worth Handyman"
  description="Professional smart home installation in Fort Worth. Doorbell cameras, smart thermostats, smart locks, lighting, and device setup."
>
  <Navbar />

  <section class="max-w-6xl mx-auto px-6 py-20">
    <h1 class="text-4xl md:text-5xl font-bold mb-6">
      Smart Home Installation in Fort Worth
    </h1>

    <p class="text-lg mb-10 text-gray-700">
      Upgrade your home with modern smart technology. West Fort Worth Handyman
      provides professional smart home installation services including video
      doorbells, smart thermostats, smart locks, lighting systems, and home
      automation setup. We help homeowners in Fort Worth install and configure
      devices so everything works together reliably.
    </p>

    <div class="grid md:grid-cols-2 gap-10">
      <div>
        <h2 class="text-2xl font-semibold mb-4">Smart Devices We Install</h2>

        <ul class="space-y-3 list-disc ml-6">
          <li>Video doorbell installation</li>
          <li>Smart thermostat installation</li>
          <li>Smart lock installation</li>
          <li>Smart light switches and dimmers</li>
          <li>Smart security camera installation</li>
          <li>WiFi connected garage door openers</li>
          <li>Smart plugs and automation devices</li>
          <li>Google Home and Alexa device setup</li>
        </ul>
      </div>

      <div>
        <h2 class="text-2xl font-semibold mb-4">
          Professional Setup and Configuration
        </h2>

        <p class="mb-4">
          Installing smart devices is only part of the job. Proper configuration
          ensures your devices connect correctly, work with your WiFi network,
          and integrate with apps like Google Home or Amazon Alexa.
        </p>

        <p>
          We help Fort Worth homeowners avoid frustrating setup issues by
          installing, connecting, and testing each device to make sure
          everything works as expected.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-gray-100 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-10">Popular Smart Home Installations</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-lg shadow">
          <h3 class="font-semibold text-xl mb-3">Video Doorbells</h3>
          <p>
            Installation and setup for Ring, Nest, and other video doorbells to
            improve security and monitor your home from anywhere.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow">
          <h3 class="font-semibold text-xl mb-3">Smart Thermostats</h3>
          <p>
            Professional installation for smart thermostats that help improve
            comfort and reduce energy costs.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow">
          <h3 class="font-semibold text-xl mb-3">Smart Locks</h3>
          <p>
            Install keyless entry systems and smart locks that allow secure
            remote access to your home.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-20 text-center">
    <h2 class="text-3xl font-bold mb-6">
      Need Smart Home Installation in Fort Worth?
    </h2>

    <p class="text-lg mb-8">
      If you're upgrading your home with smart technology, West Fort Worth
      Handyman can help install and configure your devices correctly the first
      time.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="tel:+16827030033"
        class="bg-brand-red px-8 py-4 rounded-lg text-white font-semibold"
      >
        Call {phone}
      </a>

      <a
        href="/contact"
        class="border-2 border-brand-navy px-8 py-4 rounded-lg font-semibold"
      >
        Request Estimate
      </a>
    </div>
  </section>
</BaseLayout>

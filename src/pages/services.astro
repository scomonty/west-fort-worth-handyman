---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import FAQ from "../components/FAQ.astro";
import ServiceDetail from "../components/ServiceDetail.astro";
---

<BaseLayout
  title="Handyman Services in West Fort Worth"
  description="Affordable and reliable handyman services in West Fort Worth. Drywall repair, door repair, fixture installation, and home maintenance."
>
  <Navbar />

  <!-- PAGE HERO -->
  <section class="bg-brand-navy text-white pt-40 pb-24 text-center">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Handyman Services in Fort Worth, TX
      </h1>

      <p class="text-lg text-gray-200">
        Reliable home repairs, maintenance, and installation services for West
        Fort Worth homeowners.
      </p>
      <p class="mt-6">
        Our handyman services in Fort Worth include drywall repair, flooring
        installation, fixture installation, fence repair, smart home
        installation, door repair, and general home maintenance.
      </p>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-24 bg-brand-offwhite">
    <div class="max-w-6xl mx-auto px-6 space-y-24">
      <!-- Interior Repairs -->
      <div>
        <h2 class="text-3xl font-bold text-brand-navy mb-6">
          Interior Repairs
        </h2>
        <p class="text-brand-gray mb-6 max-w-3xl">
          We provide professional interior home repairs for Fort Worth
          homeowners including drywall repair, trim repair, door adjustments,
          caulking, and wall damage repair. Our handyman services help restore
          the appearance and functionality of your home quickly and reliably.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            <ServiceDetail
              title="Drywall patching and repair"
              description="We provide professional drywall patching and repair to restore your walls and ceilings to a smooth, like-new finish."
              detailsUrl="/drywall-repair-fort-worth"
              detailsLabel="Learn more about drywall repair in Fort Worth"
              images={["/projects/wall-repair1.jpg"]}
            />
          </div>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            <ServiceDetail
              title="Caulking and sealing"
              description="We provide professional caulking and sealing to protect your home from water, air leaks, and everyday wear. We seal gaps around windows, doors, trim, and fixtures to improve energy efficiency, prevent moisture damage, and create clean, finished lines."
              images={["/projects/caulking1.jpg"]}
            />
          </div>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            <ServiceDetail
              title="Door repair and adjustment"
              description="Professional door repair services including hinge adjustment, door alignment, hardware replacement, and interior door installation."
              detailsUrl="/door-repair-fort-worth"
              detailsLabel="Learn more about door repair in Fort Worth"
              highlights={[
                "Door alignment and adjustment",
                "Hinge replacement",
                "Door latch repair",
                "Door frame adjustments",
                "Interior door installation",
              ]}
            />
          </div>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            <ServiceDetail
              title="Trim and Baseboard Repair"
              description="Professional trim and baseboard repair in Fort Worth including fixing loose molding, repairing cracked or damaged baseboards, replacing sections of trim, and securing trim that has separated from the wall. Clean repairs that restore a finished look to your home."
              highlights={[
                "Baseboard repair and replacement",
                "Trim gap repairs",
                "Loose molding repair",
                "Cracked trim replacement",
                "Clean finished edges",
              ]}
            />
          </div>
        </div>
      </div>

      <!-- Installations -->
      <div>
        <h2 class="text-3xl font-bold text-brand-navy mb-6">
          Flooring Installations
        </h2>

        <!-- Flooring Installation -->
        <div class="mb-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="Laminate flooring installation"
                description="We provide professional laminate flooring installation that delivers a durable, stylish finish for any room in your home. From surface preparation to precise fitting and clean transitions, we ensure a smooth, long-lasting result that enhances the look and value of your space. Quality workmanship, efficient installation, and attention to detail every step of the way."
                detailsUrl="/flooring-installation-fort-worth"
                detailsLabel="Learn more about flooring installation in Fort Worth"
                images={[
                  "/projects/laminate1.jpg",
                  "/projects/laminate2.jpg",
                  "/projects/laminate3.jpg",
                  "/projects/laminate4.jpg",
                ]}
              />
            </div>

            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="Vinyl plank flooring installation"
                description="We provide professional vinyl plank flooring installation for a durable, water-resistant, and modern finish. Our process includes proper surface preparation, precise installation, and seamless transitions to ensure long-lasting performance and a clean, polished look."
                images={["/projects/vinyl1.jpg"]}
              />
            </div>

            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail title="Hardwood flooring installation" />
            </div>

            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail title="Flooring replacement and repair" />
            </div>
          </div>
        </div>
        <div>
          <h2 class="text-3xl font-bold text-brand-navy mb-6">
            Installation Services
          </h2>
          <div class="grid md:grid-cols-2 gap-6">
            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="Light Fixture Installation"
                description="Professional installation and replacement of light fixtures including ceiling lights, pendant lighting, and wall fixtures. Safe wiring and clean installation."
                images={["/projects/light-install1.jpg"]}
              />
            </div>
            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="Ceiling Fan Installation"
                description="Professional ceiling fan installation and replacement including secure mounting, wiring, and fan balancing."
                images={["/projects/fan-install1.jpg"]}
                detailsUrl="/ceiling-fan-installation-fort-worth"
                detailsLabel="Learn more about ceiling fan installation in Fort Worth"
              />
            </div>
            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="Faucet Installation"
                description="Kitchen and bathroom faucet installation and replacement including fixture upgrades and leak prevention."
              />
            </div>
            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="Shelving & Mounting"
                description="Professional installation of wall shelving, TV mounting, picture hanging, and storage solutions. Secure mounting into studs or proper anchors for safe, level installation and a clean finished look."
                images={["/projects/shelving1.png"]}
              />
            </div>
            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="Smart Home Device Installation"
                description="Professional installation and setup of smart home devices including video doorbells, smart thermostats, smart locks, security cameras, smart lighting, and WiFi-enabled devices. We ensure proper installation, secure mounting, and reliable connection to your home network."
                detailsUrl="/smart-home-installation-fort-worth"
                detailsLabel="Learn more about smart home installation in Fort Worth"
                images={["/projects/smart-home-1.jpg"]}
              />
            </div>
            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="TV Mounting"
                description="Professional TV wall mounting including bracket installation, stud mounting, cable concealment, and soundbar installation."
                detailsUrl="/tv-mounting-fort-worth"
                detailsLabel="Learn more about TV mounting in Fort Worth"
                highlights={[
                  "Flat screen TV mounting",
                  "Mounting above fireplaces",
                  "Stud-secured installations",
                  "Cable concealment",
                  "Soundbar mounting",
                ]}
              />
            </div>
            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="Bathroom Hardware Installation"
                description="Bathroom hardware installation in Fort Worth including towel bars, toilet paper holders, robe hooks, mirrors, and wall-mounted accessories. Secure mounting and precise alignment for a clean, durable installation."
                highlights={[
                  "Towel bar installation",
                  "Toilet paper holder installation",
                  "Robe hook installation",
                  "Bathroom mirror mounting",
                  "Secure wall anchor installation",
                ]}
              />
            </div>
            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="Cabinet Hardware Installation"
                description="Installation of cabinet pulls, knobs, and handles for kitchens, bathrooms, and built-in storage. Precise alignment and secure installation for a clean, professional finish."
                highlights={[
                  "Kitchen cabinet hardware installation",
                  "Drawer pulls and cabinet knobs",
                  "Hardware replacement and upgrades",
                  "Even spacing and professional alignment",
                  "Secure mounting for durable use",
                ]}
              />
            </div>
            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="Curtain Rod and Blind Installation"
                description="Professional installation of curtain rods, window blinds, and window treatments. Secure mounting and proper alignment for smooth operation and a finished look."
              />
            </div>
            <div
              class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200
h-full flex flex-col"
            >
              <ServiceDetail
                title="Picture Hanging and Wall Mounting"
                description="Secure installation of wall decor including large mirrors, artwork, shelves, and wall-mounted items. Proper anchors and stud mounting ensure safe and level installation."
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Exterior Repairs -->
      <div>
        <h2 class="text-3xl font-bold text-brand-navy mb-6">
          Exterior Repairs
        </h2>
        <p class="text-brand-gray mb-6 max-w-3xl">
          Exterior repair services include fence repair, siding repairs, trim
          repair, and weatherproofing to protect your home from damage and
          maintain its appearance.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            <ServiceDetail
              title="Fence and Gate Repair"
              description="Repair broken fence boards, sagging gates, and damaged fence sections to restore strength and security."
              detailsUrl="/fence-repair-fort-worth"
              detailsLabel="Learn more about fence repair in Fort Worth"
            />
          </div>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            <ServiceDetail
              title="Minor Siding Repair"
              description="Repair damaged or loose siding to protect your home from moisture and weather exposure. We fix cracked panels, loose sections, and minor exterior siding damage to restore the appearance and durability of your home's exterior."
              highlights={[
                "Loose siding repair",
                "Cracked siding replacement",
                "Minor siding damage repair",
                "Exterior trim and siding adjustments",
                "Secure reattachment of siding panels",
              ]}
            />
          </div>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            <ServiceDetail
              title="Weatherproofing and sealing"
              highlights={[
                "Window and door draft sealing",
                "Weather stripping installation",
                "Exterior gap and crack sealing",
                "Trim and siding gap sealing",
                "Moisture and air leak prevention",
              ]}
            />
          </div>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            <ServiceDetail title="Exterior trim repair" />
          </div>
        </div>
      </div>

      <!-- Plumbing -->
      <div>
        <h2 class="text-3xl font-bold text-brand-navy mb-6">
          Minor Plumbing Services
        </h2>
        <p class="text-brand-gray mb-6 max-w-3xl">
          We provide minor plumbing repairs and fixture replacement including
          faucets, toilets, and leak repairs for kitchens, bathrooms, and
          utility rooms.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            Faucet replacement
          </div>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            Leak repairs
          </div>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            Toilet repairs
          </div>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            Fixture replacement
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-3xl font-bold text-brand-navy mb-6">
          Installation & Project Assistance
        </h2>

        <p class="text-brand-gray mb-4">
          Working on a home project but need an extra set of hands? We provide
          skilled assistance for installations, lifting, assembly, and DIY home
          improvement projects. Whether you're tackling a project yourself or
          need help finishing a job, we can help you get it done safely and
          correctly.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            Help with DIY home projects
          </div>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            Furniture assembly and installation
          </div>
          <div
            class="bg-white p-6 rounded-xl shadow-sm border border-gray-100
hover:shadow-lg hover:-translate-y-1 transition duration-200"
          >
            Fixture and appliance installation assistance
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 text-center bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">
        Need Help With a Repair?
      </h2>

      <p class="text-brand-gray mb-8">
        Contact West Fort Worth Handyman today for reliable service and a fair
        estimate.
      </p>

      <a
        href="/contact"
        class="bg-brand-red text-white px-8 py-4 rounded-lg font-semibold hover:opacity-90"
      >
        Request an Estimate
      </a>
    </div>
  </section>

  <FAQ
    items={[
      {
        question: "What types of home repairs do you handle?",
        answer:
          "We handle a wide range of small to mid-sized home repairs including drywall repair and patching, door and trim repair, flooring installation, fence repair, fixture installation, caulking and sealing, and general home maintenance projects.",
      },
      {
        question: "Do you handle small repair jobs and odd tasks?",
        answer:
          "Yes. We specialize in small home repairs and maintenance tasks that many contractors will not take. We help homeowners complete repair lists and improvement projects efficiently.",
      },
      {
        question: "How much do handyman services cost?",
        answer:
          "Project costs vary based on the type of repair, materials needed, and time required. We provide free estimates and upfront pricing so you know what to expect before work begins.",
      },
      {
        question: "Do you provide materials or should I purchase them?",
        answer:
          "We can provide most standard materials for your project or work with materials you supply. We will discuss options during your estimate.",
      },
      {
        question: "What types of flooring do you install?",
        answer:
          "We install vinyl plank flooring and laminate flooring for residential homes, providing durable and attractive results with professional installation.",
      },
      {
        question: "Can you repair damaged drywall and match texture?",
        answer:
          "Yes. We repair drywall damage including holes, cracks, and water damage and match existing wall texture for a seamless finish.",
      },
      {
        question: "Do you offer fence and exterior repairs?",
        answer:
          "Yes. We repair fences, exterior features, and other outdoor structures to improve safety, function, and appearance.",
      },
      {
        question: "How should I prepare my home before service?",
        answer:
          "We recommend clearing the work area and providing access to the repair location. We will discuss any additional preparation during scheduling.",
      },
      {
        question: "Do you guarantee your work?",
        answer:
          "We take pride in quality workmanship and complete every project with attention to detail to ensure customer satisfaction.",
      },
      {
        question: "Can you help with rental property maintenance?",
        answer:
          "Yes. We provide reliable repair and maintenance services for rental properties and investment homes in Fort Worth and surrounding areas.",
      },
    ]}
  />
</BaseLayout>

---
const {
  id,
  title,
  city,
  state,
  before,
  after,
  description,
  scope,
  services = [],
  highlights = [],
} = Astro.props;

const afterImages = Array.isArray(after) ? after : [after];
const allImages = before ? [before, ...afterImages] : afterImages;
---

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    "@id": `${Astro.url.href}#${title.replace(/\s+/g, "-")}`,

    name: title,
    description: description,

    creator: {
      "@id": "https://westfortworthhandyman.com/#business",
    },

    image: before ? [before, ...afterImages] : afterImages,
  })}
/>

<div class="bg-white rounded-xl shadow p-6">
  <!-- Title + Scope -->
  <div class="flex items-start justify-between mb-2">
    <h3 class="text-xl font-bold">{title}</h3>

    {
      scope && (
        <span class="text-xs bg-gray-100 px-3 py-1 rounded-full">{scope}</span>
      )
    }
  </div>

  <!-- Location -->
  {
    (city || state) && (
      <p class="text-sm text-gray-500 mb-4">
        {[city, state].filter(Boolean).join(", ")}
      </p>
    )
  }

  <!-- Images -->
  <div
    class={`grid ${before ? "md:grid-cols-2" : "md:grid-cols-1"} gap-4 mb-4`}
  >
    {
      before && (
        <div>
          <p class="text-sm font-semibold mb-2">Before</p>
          <img
            src={before}
            alt={`${title} before`}
            class="rounded-lg w-full h-64 object-cover cursor-pointer hover:opacity-90"
            onclick={`openImageModal('${id}', '${JSON.stringify(allImages)}', 0)`}
          />
        </div>
      )
    }

    <!-- AFTER -->
    <div>
      <p class="text-sm font-semibold mb-2">
        {before ? "After" : "Project Photos"}
      </p>

      <!-- show first image -->
      <img
        src={afterImages[0]}
        alt={`${title} after`}
        class="rounded-lg w-full h-64 object-cover cursor-pointer hover:opacity-90"
        onclick={`openImageModal('${id}', '${JSON.stringify(allImages)}', ${before ? 1 : 0})`}
      />

      <!-- show thumbnails if multiple -->
      {
        afterImages.length > 1 && (
          <div class="flex flex-wrap gap-2 mt-2">
            {afterImages.slice(1).map((img, index) => {
              const realIndex = allImages.indexOf(img);

              return (
                <img
                  src={img}
                  class="w-16 h-16 object-cover rounded cursor-pointer hover:opacity-80"
                  onclick={`openImageModal('${id}', '${JSON.stringify(allImages)}', ${realIndex})`}
                />
              );
            })}
          </div>
        )
      }
    </div>
  </div>

  <!-- Description -->
  {description && <p class="text-brand-gray mb-4">{description}</p>}

  <!-- Highlights -->
  {
    highlights.length > 0 && (
      <ul class="text-sm text-gray-700 space-y-1 mb-4">
        {highlights.map((item) => (
          <li>✓ {item}</li>
        ))}
      </ul>
    )
  }

  <!-- Services Tags -->
  {
    services.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {services.map((service) => (
          <span class="text-xs bg-gray-100 px-3 py-1 rounded-full">
            {service}
          </span>
        ))}
      </div>
    )
  }

  <!-- MODAL -->
  <div
    id={`${id}-modal`}
    class="fixed inset-0 bg-black/80 flex items-center justify-center z-[9999] hidden"
    onclick={`closeImageModal('${id}')`}
  >
    <div
      class="relative max-w-4xl w-full p-4"
      onclick="event.stopPropagation()"
    >
      <button
        class="absolute -top-10 right-0 text-white text-3xl"
        onclick={`closeImageModal('${id}')`}
      >
        ×
      </button>

      <img
        id={`${id}-modal-img`}
        class="w-full max-h-[80vh] object-contain rounded-lg"
      />
      <button
        id={`${id}-prev`}
        class="absolute left-4 top-1/2 -translate-y-1/2
         bg-black/60 backdrop-blur-sm
         text-white text-4xl
         w-14 h-14 rounded-full
         flex items-center justify-center
         hover:bg-black/80 hover:scale-110
         transition shadow-lg cursor-pointer"
        onclick={`prevModalImage('${id}')`}
      >
        ‹
      </button>

      <button
        id={`${id}-next`}
        class="absolute right-4 top-1/2 -translate-y-1/2
         bg-black/60 backdrop-blur-sm
         text-white text-4xl
         w-14 h-14 rounded-full
         flex items-center justify-center
         hover:bg-black/80 hover:scale-110
         transition shadow-lg cursor-pointer"
        onclick={`nextModalImage('${id}')`}
      >
        ›
      </button>
    </div>
  </div>
</div>

<script>
  window.modalState = {};

  window.openImageModal = (id, images, startIndex = 0) => {
    document.body.style.overflow = "hidden";
    const parsedImages =
      typeof images === "string" ? JSON.parse(images) : images;

    const modal = document.getElementById(`${id}-modal`);
    const img = document.getElementById(`${id}-modal-img`);

    window.modalState[id] = {
      images: parsedImages,
      index: startIndex,
    };

    img.src = parsedImages[startIndex];
    modal.classList.remove("hidden");

    updateModalArrows(id);
    addSwipeSupport(id);
    addKeyboardSupport(id);
  };

  window.closeImageModal = (id) => {
    document.body.style.overflow = "";
    document.body.style.overflow = "";
    document.getElementById(`${id}-modal`).classList.add("hidden");

    const state = window.modalState[id];
    if (state?.keyHandler) {
      document.removeEventListener("keydown", state.keyHandler);
    }
  };

  window.nextModalImage = (id) => {
    const state = window.modalState[id];
    if (!state) return;

    if (state.index < state.images.length - 1) state.index++;

    document.getElementById(`${id}-modal-img`).src = state.images[state.index];

    updateModalArrows(id);
  };

  window.prevModalImage = (id) => {
    const state = window.modalState[id];
    if (!state) return;

    if (state.index > 0) state.index--;

    document.getElementById(`${id}-modal-img`).src = state.images[state.index];

    updateModalArrows(id);
  };

  function updateModalArrows(id) {
    const state = window.modalState[id];
    if (!state) return;

    const prev = document.getElementById(`${id}-prev`);
    const next = document.getElementById(`${id}-next`);

    prev.style.display = state.index === 0 ? "none" : "block";
    next.style.display =
      state.index === state.images.length - 1 ? "none" : "block";
  }

  function addSwipeSupport(id) {
    const modal = document.getElementById(`${id}-modal`);
    const img = document.getElementById(`${id}-modal-img`);

    if (!img) return;

    let startX = 0;
    let endX = 0;

    img.addEventListener("touchstart", (e) => {
      startX = e.changedTouches[0].screenX;
    });

    img.addEventListener("touchend", (e) => {
      endX = e.changedTouches[0].screenX;
      handleSwipe(id);
    });

    function handleSwipe(id) {
      const threshold = 50; // minimum swipe distance
      const diff = startX - endX;

      if (Math.abs(diff) < threshold) return;

      if (diff > 0) {
        // swipe left → next image
        window.nextModalImage(id);
      } else {
        // swipe right → previous image
        window.prevModalImage(id);
      }
    }
  }

  function addKeyboardSupport(id) {
    function handleKey(e) {
      const modal = document.getElementById(`${id}-modal`);

      // Only work if modal is visible
      if (!modal || modal.classList.contains("hidden")) return;

      if (e.key === "ArrowRight") {
        e.preventDefault();
        window.nextModalImage(id);
      }

      if (e.key === "ArrowLeft") {
        e.preventDefault();
        window.prevModalImage(id);
      }

      if (e.key === "Escape") {
        e.preventDefault();
        window.closeImageModal(id);
      }
    }

    // store handler so we can remove later
    window.modalState[id].keyHandler = handleKey;

    document.addEventListener("keydown", handleKey);
  }
</script>
